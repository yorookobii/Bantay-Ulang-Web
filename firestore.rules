rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // -------------------------------------------------------------------------
    // users
    // -------------------------------------------------------------------------
    match /users/{userId} {
      // Any authenticated user can read user documents.
      // Needed so the web admin login can fetch any user doc to verify their role.
      allow read: if isAuthenticated();

      // Users can write their own document; admins can write any user document.
      allow write: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
    }

    // -------------------------------------------------------------------------
    // sensor_readings
    // -------------------------------------------------------------------------
    match /sensor_readings/{docId} {
      // Authenticated users (web + Flutter) can read.
      allow read: if isAuthenticated();

      // ESP32 writes without auth — no authentication required for create.
      allow create: if true;

      // Only admins can update or delete sensor readings.
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // alerts
    // -------------------------------------------------------------------------
    match /alerts/{docId} {
      // Authenticated users can read alerts.
      allow read: if isAuthenticated();

      // ESP32 / alertsEngine (unauthenticated server logic) can create and
      // auto-resolve (update) alerts.
      allow create, update: if true;

      // Only admins can delete alert documents.
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // growth_indicators
    // -------------------------------------------------------------------------
    match /growth_indicators/{docId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // ulang_growth_records
    // -------------------------------------------------------------------------
    match /ulang_growth_records/{docId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
                       request.resource.data.recordedBy == request.auth.uid;

      allow update: if isAdmin() ||
                       (isAuthenticated() &&
                        resource.data.recordedBy == request.auth.uid);

      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // feeding_records
    // -------------------------------------------------------------------------
    match /feeding_records/{docId} {
      allow read, write: if isAuthenticated();
    }

    // -------------------------------------------------------------------------
    // feeding_schedules
    // -------------------------------------------------------------------------
    match /feeding_schedules/{docId} {
      allow read, write: if isAuthenticated();
    }

    // -------------------------------------------------------------------------
    // logs  (Flutter: filter by createdBy / assignedTo)
    // -------------------------------------------------------------------------
    match /logs/{docId} {
      // Admins see all logs; other users see only logs they created or are
      // assigned to (Flutter assignedTo filter preserved).
      allow read: if isAdmin() ||
                    (isAuthenticated() &&
                     (resource.data.createdBy == request.auth.uid ||
                      resource.data.assignedTo == request.auth.uid));

      // Any authenticated user can create a log they own.
      allow create: if isAuthenticated() &&
                       request.resource.data.createdBy == request.auth.uid;

      // Admins or the log creator can update; only admins can delete.
      allow update: if isAdmin() ||
                       (isAuthenticated() &&
                        resource.data.createdBy == request.auth.uid);

      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // tasks  (Flutter: filter by createdBy / assignedTo)
    // -------------------------------------------------------------------------
    match /tasks/{docId} {
      // Admins see all tasks; other users see only tasks they created or are
      // assigned to (Flutter assignedTo filter preserved).
      allow read: if isAdmin() ||
                    (isAuthenticated() &&
                     (resource.data.createdBy == request.auth.uid ||
                      resource.data.assignedTo == request.auth.uid));

      // Any authenticated user can create a task they own.
      allow create: if isAuthenticated() &&
                       request.resource.data.createdBy == request.auth.uid;

      // Admins or the task creator can update; only admins can delete.
      allow update: if isAdmin() ||
                       (isAuthenticated() &&
                        resource.data.createdBy == request.auth.uid);

      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Default deny — all other collections and documents are blocked.
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
