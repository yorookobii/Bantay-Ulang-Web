rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user has the 'admin' role
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // -------------------------------------------------------------------------
    // users
    // -------------------------------------------------------------------------
    match /users/{userId} {
      // A user can read/write their own document; admins can read/write any user doc.
      allow read: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
      allow write: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
    }

    // -------------------------------------------------------------------------
    // sensor_readings
    // -------------------------------------------------------------------------
    match /sensor_readings/{docId} {
      // Any authenticated user can read; unauthenticated (ESP32) can create.
      allow read:   if isAuthenticated();
      allow create: if true;
    }

    // -------------------------------------------------------------------------
    // alerts
    // -------------------------------------------------------------------------
    match /alerts/{docId} {
      // Authenticated users can read; unauthenticated (ESP32 / system) can
      // create and update (e.g. auto-resolve alerts).
      allow read:          if isAuthenticated();
      allow create, update: if true;
    }

    // -------------------------------------------------------------------------
    // growth_indicators
    // -------------------------------------------------------------------------
    match /growth_indicators/{docId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // ulang_growth_records
    // -------------------------------------------------------------------------
    match /ulang_growth_records/{docId} {
      // Any authenticated user can read all records.
      allow read: if isAuthenticated();

      // Users can create their own records only.
      allow create: if isAuthenticated() &&
                       request.resource.data.recordedBy == request.auth.uid;

      // Users cannot update or delete others' records.
      // Admins can update and delete any record.
      allow update: if isAdmin() ||
                       (isAuthenticated() &&
                        resource.data.recordedBy == request.auth.uid);

      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // feeding_records
    // -------------------------------------------------------------------------
    match /feeding_records/{docId} {
      allow read, write: if isAuthenticated();
    }

    // -------------------------------------------------------------------------
    // feeding_schedules
    // -------------------------------------------------------------------------
    match /feeding_schedules/{docId} {
      allow read, write: if isAuthenticated();
    }

    // -------------------------------------------------------------------------
    // logs
    // -------------------------------------------------------------------------
    match /logs/{docId} {
      // Users can read/write their own log entries; admins can read/write all.
      allow read, write: if isAdmin() ||
                            (isAuthenticated() &&
                             (resource.data.createdBy == request.auth.uid ||
                              resource.data.assignedTo == request.auth.uid));

      // Allow creating a new log if the createdBy field matches the requester.
      allow create: if isAuthenticated() &&
                       request.resource.data.createdBy == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // tasks
    // -------------------------------------------------------------------------
    match /tasks/{docId} {
      // Users can read/write tasks they created or are assigned to;
      // admins can read/write all.
      allow read, write: if isAdmin() ||
                            (isAuthenticated() &&
                             (resource.data.createdBy == request.auth.uid ||
                              resource.data.assignedTo == request.auth.uid));

      // Allow creating a new task if the createdBy field matches the requester.
      allow create: if isAuthenticated() &&
                       request.resource.data.createdBy == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // Default deny — all other collections and documents are blocked.
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
